# Copy to .env for local development: `cp .env.example .env`
# Loaded by `npm run server` via Node's --env-file flag.
# Credentials are NOT set here — the AWS SDK reads them from your default
# chain (~/.aws/credentials, `aws configure`, or an IAM role). This file
# only selects the region (and optionally the DynamoDB table name).

# Setting AWS_REGION enables DynamoDB persistence of game results locally.
# Leave it unset to run the server without persistence.
AWS_REGION=us-east-1

# Optional: override the DynamoDB table name (defaults to GameResults).
# DYNAMODB_TABLE_NAME=GameResults
